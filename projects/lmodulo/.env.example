# Copy to .env and adjust as needed
# docker compose reads .env automatically

WEB_PORT=3000
API_PORT=4000
MONGO_PORT=27017
MONGO_DB=appdb

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-random-64-char-hex-string

# Email / password reset
# Leave SMTP_HOST blank in dev — Ethereal test account is auto-provisioned and preview URLs logged to console
# Production examples: smtp.resend.com (Resend), smtp.postmarkapp.com (Postmark), smtp.mailgun.org (Mailgun)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Architectonic <noreply@example.com>
APP_URL=http://localhost:3000
APP_NAME=

CALENDAR_REMINDER_INTERVAL_MS=1800000 # How often (ms) the reminder scheduler polls for upcoming events. Default: 30 minutes.

# Stripe — Folio finance module
# Get keys from https://dashboard.stripe.com/apikeys (use test keys for dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...