{
  "name": "calendar-events",
  "description": "Typed calendar events (upcoming events, deadlines, project scopes, announcements) with subscribe/notification model",
  "nav": [
    {
      "label": "Calendar",
      "href": "/calendar-events",
      "icon": "CalendarDays"
    },
    {
      "label": "Manage Events",
      "href": "/calendar-events/admin",
      "icon": "CalendarCog",
      "permission": "calendar_events.create"
    }
  ],
  "permissions": [
    {
      "resource": "calendar_events",
      "actions": ["create", "read", "update", "delete"]
    }
  ],
  "dependencies": {
    "frontend": {},
    "api": {}
  },
  "exclude": [
    "frontend/tsconfig.json",
    "frontend/src/ambient.d.ts",
    "frontend/src/routes/calendar-events/$types.d.ts",
    "frontend/src/routes/calendar-events/admin/$types.d.ts",
    "frontend/src/routes/api/calendar-events/$types.d.ts",
    "frontend/src/routes/api/calendar-events/[id]/$types.d.ts",
    "frontend/src/routes/api/calendar-events/public/$types.d.ts",
    "frontend/src/routes/api/calendar-events/subscriptions/$types.d.ts"
  ],
  "env": [
    {
      "key": "CALENDAR_REMINDER_INTERVAL_MS",
      "required": false,
      "default": "1800000",
      "description": "How often (ms) the reminder scheduler polls for upcoming events. Default: 30 minutes."
    }
  ]
}
