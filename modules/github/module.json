{
  "name": "github",
  "description": "GitHub repository viewer and contribution charts",
  "nav": [
    {
      "label": "GitHub",
      "href": "/github",
      "icon": "Github",
      "permission": "github.read"
    }
  ],
  "permissions": [
    {
      "resource": "github",
      "actions": ["create", "read", "update", "delete"]
    }
  ],
  "dependencies": {
    "frontend": {},
    "api": {}
  },
  "env": [
    { "key": "GITHUB_TOKEN", "required": true, "default": "", "description": "GitHub PAT with repo scope" },
    { "key": "GITHUB_OWNER", "required": true, "default": "", "description": "GitHub username or org name" },
    { "key": "GITHUB_OWNER_TYPE", "required": false, "default": "user", "description": "user or org" }
  ],
  "widgets": [
    {
      "component": "ContributionChart",
      "import": "$lib/components/github/ContributionChart.svelte",
      "permission": "github.read",
      "order": 10
    }
  ]
}
